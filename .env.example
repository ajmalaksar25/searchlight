# --- Google OAuth client (Tier 0: bring-your-own; pick ONE option) ---

# Option A: paste the two values directly
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=

# Option B: point to the client_secret JSON you downloaded from Google Cloud
# (leave the two values above blank if you use this)
# GSC_OAUTH_CREDENTIALS=/absolute/path/to/client_secret.json

# --- Optional ---

# Default property used when a tool call omits siteUrl and no session site is set.
# Either a URL-prefix property ("https://example.com/") or "sc-domain:example.com".
# GSC_DEFAULT_SITE=

# API key for PageSpeed Insights / CrUX (page-speed & Core Web Vitals tools).
# GSC_PAGESPEED_API_KEY=

# Request read+write scope so sitemap submit/delete tools are enabled.
# Leave unset for safe read-only access.
# GSC_ENABLE_WRITE=1

# Where to store the auth token + config (default: ~/.gsc-mcp)
# GSC_MCP_HOME=/absolute/path/to/dir

# --- Tier 1 (maintainer use): bundled verified OAuth client ---
# When set, users need no OAuth vars at all. Leave unset for Tier 0.
# GSC_BUNDLED_CLIENT_ID=
# GSC_BUNDLED_CLIENT_SECRET=
