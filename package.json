{
  "name": "@ajmalaksar/searchlight",
  "version": "0.1.0",
  "description": "Searchlight: an autonomous technical-SEO and analytics agent (MCP server). Detect indexing, canonical, redirect, sitemap, speed and on-page issues, then fix them in your repo, deploy, and verify. Works with Claude Code, Codex, and any MCP client.",
  "type": "module",
  "bin": {
    "searchlight": "dist/index.js"
  },
  "files": [
    "dist",
    "skill",
    "bundled-client.json",
    "bundled-keys.json",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "login": "node dist/index.js login",
    "status": "node dist/index.js status",
    "setup": "node dist/index.js setup",
    "start": "node dist/index.js serve",
    "keys:sync": "node scripts/sync-keys.mjs",
    "test": "npm run build && node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "technical-seo",
    "seo",
    "google-search-console",
    "ga4",
    "indexing",
    "core-web-vitals",
    "search-analytics",
    "claude",
    "codex",
    "llm"
  ],
  "author": "Ajmal Aksar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajmalaksar25/searchlight.git"
  },
  "homepage": "https://searchlight.ajmalaksar.com",
  "bugs": {
    "url": "https://github.com/ajmalaksar25/searchlight/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "googleapis": "^173.0.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
